{
  "name": "donna-windows",
  "version": "0.1.0",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron .",
    "preview": "electron-vite preview",
    "dist": "electron-vite build && electron-builder --win",
    "gen-icon": "node scripts/gen-icon.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "com.yourcompany.donna",
    "productName": "Donna",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      { "from": "assets/", "to": "assets/" }
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.png",
      "executableName": "Donna"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Donna"
    }
  },
  "dependencies": {
    "@donna/shared": "*",
    "@ricky0123/vad-web": "^0.0.30"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "34.5.8",
    "electron-builder": "^25.0.0",
    "electron-vite": "^3.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "typescript": "^5.3.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0",
    "@vitest/ui": "^2.0.0",
    "jsdom": "^25.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/react-hooks": "^8.0.0",
    "@testing-library/dom": "^10.0.0"
  }
}
